// Don't forget to tell Prisma about your edits to this file using
// `yarn rw prisma migrate dev` or `yarn rw prisma db push`.
// `migrate` is like committing while `push` is for prototyping.
// Read more about both here:
// https://www.prisma.io/docs/orm/prisma-migrate

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin", "darwin-arm64"] // Add "darwin" and/or "darwin-arm64"
}

// Enums
enum Role {
  ADMIN
  COACH
  PLAYER
  PARENT
  PROSPECT
}

enum ProgramLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ELITE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum CertificateStatus {
  DRAFT
  ISSUED
  REVOKED
  EXPIRED
}

enum AnnouncementType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

// User Model
model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  hashedPassword      String
  salt                String
  resetToken          String?
  resetTokenExpiresAt DateTime?
  role                Role      @default(PLAYER)
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relationships
  profile             Profile?
  enrollments         Enrollment[]
  attendances         Attendance[]
  payments            Payment[]
  invoices            Invoice[]
  certificates        Certificate[]
  skillAssessments    SkillAssessment[]
  playerStats         PlayerStats[]
  announcements       Announcement[] @relation("CreatedBy")
  sentMessages        Message[] @relation("Sender")
  receivedMessages    Message[] @relation("Recipient")
  classesAsTutor      Class[] @relation("Coach")
  // Site assets relation
  gallery             Gallery[] @relation("CreatedBy")
  invitations         InvitationLink[] @relation("CreatedBy") // 👈 One-to-many relationship
  teamId              String?
  team                AgeGroupTeam?  @relation("TeamPlayers", fields: [teamId], references: [id], onDelete: SetNull)
  teamsAsCoach        AgeGroupTeam[] @relation("TeamCoach")

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@index([createdAt])
}

// Profile Model
model Profile {
  id                    String    @id @default(cuid())
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName             String
  lastName              String
  gender                String?
  dateOfBirth           DateTime?
  phoneNumber           String?
  address               String?
  city                  String?
  state                 String?
  zipCode               String?
  country               String?
  position              String?
  jerseyNumber          Int?
  heightCm              Float?
  weightKg              Float?
  medicalInfo           String?
  emergencyContactName  String?
  emergencyContactPhone String?
  relationshipToPlayer  String?
  playerUserId          String?
  profilePhoto          String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

// Program Model
model Program {
  id                String    @id @default(cuid())
  name              String
  description       String?
  level             ProgramLevel
  minAge            Int?
  maxAge            Int?
  capacity          Int
  durationWeeks     Int
  pricePerMonth     Float
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relationships
  classes           Class[]
  enrollments       Enrollment[]
  certificates      Certificate[]
  skillAssessments  SkillAssessment[]

  @@index([level])
  @@index([isActive])
}

// Class Model
model Class {
  id                String    @id @default(cuid())
  programId         String
  program           Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  name              String
  description       String?
  scheduleDay       String
  scheduleTime      String
  capacity          Int
  currentEnrollment Int       @default(0)
  startDate         DateTime
  endDate           DateTime?
  coachId           String
  coach             User      @relation("Coach", fields: [coachId], references: [id])
  coachName         String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relationships
  enrollments       Enrollment[]
  attendances       Attendance[]

  @@index([programId])
  @@index([coachId])
  @@index([startDate])
  @@index([isActive])
}

// Enrollment Model
model Enrollment {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  classId          String
  class           Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  programId       String
  program         Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  enrollmentDate  DateTime  @default(now())
  completionDate  DateTime?
  status          String    @default("ACTIVE")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Unique constraint
  @@unique([userId, classId])
  @@index([userId])
  @@index([classId])
  @@index([programId])
  @@index([status])
}

// Attendance Model
model Attendance {
  id              String    @id @default(cuid())
  classId         String
  class           Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  attendanceDate  DateTime
  status          AttendanceStatus
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Unique constraint
  @@unique([classId, userId, attendanceDate])
  @@index([classId])
  @@index([userId])
  @@index([attendanceDate])
}

// Payment Model
model Payment {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount                Float
  currency              String    @default("USD")
  status                PaymentStatus
  stripePaymentIntentId String?
  stripeTransactionId   String?
  description           String?
  invoiceId             String?
  invoice               Invoice?  @relation(fields: [invoiceId], references: [id])
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// Invoice Model
model Invoice {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoiceNumber String    @unique
  amount        Float
  dueDate       DateTime
  paidDate      DateTime?
  status        PaymentStatus @default(PENDING)
  description   String?
  payments      Payment[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([dueDate])
}

// Certificate Model
model Certificate {
  id                String              @id @default(cuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId         String
  program           Program             @relation(fields: [programId], references: [id], onDelete: Cascade)
  classId           String?
  title             String
  description       String?
  graduationClass   String?
  ageGroupTeam      String?
  achievementDate   DateTime
  certificateNumber String              @unique
  pdfUrl            String?
  qrCode            String?
  issuedBy          String?
  templateId        String?
  signatureUrl      String?
  verificationCode  String              @unique
  withAssessment    Boolean?             @default(false)
  status            CertificateStatus   @default(DRAFT)
  expiryDate        DateTime?
  verifiedAt        DateTime?
  revokedAt         DateTime?
  revokedReason     String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([userId])
  @@index([programId])
  @@index([achievementDate])
  @@index([status])
  @@index([certificateNumber])
  @@index([verificationCode])
  @@index([expiryDate])
}

// SkillAssessment Model
model SkillAssessment {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId      String
  program        Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  shooting       Int       // 0-100
  dribbling      Int       // 0-100
  defense        Int       // 0-100
  basketballIQ   Int       // 0-100
  athleticism    Int       // 0-100
  overallScore   Int       // 0-100
  feedback       String?
  assessedBy     String?
  assessmentDate DateTime
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
  @@index([programId])
  @@index([assessmentDate])
}

// PlayerStats Model
model PlayerStats {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameDate       DateTime
  gameName       String
  points         Int       @default(0)
  rebounds       Int       @default(0)
  assists        Int       @default(0)
  steals         Int       @default(0)
  blocks         Int       @default(0)
  minutesPlayed  Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
  @@index([gameDate])
}

// Announcement Model
model Announcement {
  id          Int    @id @default(autoincrement())
  createdById String
  title       String
  message     String
  type        AnnouncementType @default(INFO) // Enum for style
  isActive    Boolean   @default(true)
  isDismissible Boolean @default(true) // Whether users can hide it
  actionLabel String?   // e.g., "Read more"
  actionUrl   String?   // e.g., "/blog/update-1"
  priority    Int       @default(1)
  showFrom    DateTime? // When to start showing
  showUntil   DateTime? // When to stop showing
  meta        Json?     // Flexible config
  createdBy   User      @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index(fields: [title, message])
}

// Message Model
model Message {
  id          String    @id @default(cuid())
  senderId    String
  sender      User      @relation("Sender", fields: [senderId], references: [id], onDelete: SetNull)
  recipientId String
  recipient   User      @relation("Recipient", fields: [recipientId], references: [id], onDelete: SetNull)
  subject     String?
  content     String
  isRead      Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([senderId])
  @@index([recipientId])
  @@index([isRead])
}

// SiteSetting Model
model SiteSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  label     String
  group     String   @default("general")
  value     String
  valueType String   @default("text")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group])
  @@index([key])
}

// Media Model
model Media {
  id         Int        @id @default(autoincrement())
  name       String
  url        String
  pathName   String?
  mimeType   String
  size       Int
  publicId   String?
  isPublic   Boolean    @default(false)
  order      Int        @default(0)
  folderId   String?
  uploadedAt DateTime   @default(now())

  @@index(fields: [name, url, pathName])
}

// Gallery Model
model Gallery {
  id          Int             @id @default(autoincrement())
  name        String
  slug        String?
  description String?
  userId      String?
  user        User?           @relation("CreatedBy", fields: [userId], references: [id])
  images      GalleryMedia[] @relation("GalleryImages")

  status      Int      @default(1)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime?       @updatedAt

  @@index(fields: [name, slug])
}

// GalleryMedia Model
model GalleryMedia {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  image       String
  galleryId   Int?
  gallery     Gallery?   @relation("GalleryImages",fields: [galleryId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime?  @updatedAt

  @@index(fields: [name, galleryId])
}

// InvitationLink Model
model InvitationLink {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  url          String
  createdById  String?
  createdBy    User?    @relation("CreatedBy", fields: [createdById], references: [id])
  purpose      String?
  expiresAt    DateTime?
  usedAt       DateTime?
  maxUses      Int?
  useCount     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index(fields: [code, url, createdById])
}

// AgeGroupTeam Model
model AgeGroupTeam {
  id          String   @id @default(cuid())
  name        String   @unique
  ageGroup    String   // e.g. "U-12", "U-14", "U-16", "U-18"
  description String?
  coachId     String?
  coach       User?    @relation("TeamCoach", fields: [coachId], references: [id], onDelete: SetNull)
  players     User[]   @relation("TeamPlayers")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ageGroup])
  @@index([isActive])
}

